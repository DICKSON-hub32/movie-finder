<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let existing files/directories be served normally
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Send all other requests to the React SPA
  RewriteRule ^ index.html [L]
</IfModule>